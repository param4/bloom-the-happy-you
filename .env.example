# Copy to .env for local development. Expo inlines EXPO_PUBLIC_* into the
# client bundle at build time — production builds must get these from the EAS
# build environment (eas env / build profile), NOT from a committed file.

# Hide the login/welcome screen and open straight into the app as a guest.
# Opt-in: only the exact string "true" hides login; anything else shows it.
# Restart the dev server after changing.
EXPO_PUBLIC_HIDE_LOGIN=false

# Clerk publishable key — from the Clerk dashboard.
# Development: pk_test_…   Production builds: pk_live_… (via EAS env).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
