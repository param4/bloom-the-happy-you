# Feature flags (Expo inlines EXPO_PUBLIC_* into the client bundle at build time).
# Hide the login/welcome screen and open straight into the app as a guest.
# Set to "false" to restore the login flow. Restart the dev server after changing.
EXPO_PUBLIC_HIDE_LOGIN=false

# Clerk publishable key — get it from the Clerk dashboard (starts with pk_test_ / pk_live_).
# Required for real auth; without it the app cannot sign users in.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_aW50ZWdyYWwtcHJpbWF0ZS01LmNsZXJrLmFjY291bnRzLmRldiQ
